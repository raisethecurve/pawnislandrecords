{
  "rules": [
    {
      "allowed": {
        "origins": [
          "https://www.pawnislandrecords.com",
          "https://pawnislandrecords.com",
          "https://store.pawnislandrecords.com",
          "http://127.0.0.1:4173",
          "http://localhost:4173"
        ],
        "methods": ["GET", "HEAD"],
        "headers": ["Range", "Content-Type"]
      },
      "exposeHeaders": ["ETag", "Content-Length", "Content-Type", "Accept-Ranges", "Content-Range"],
      "maxAgeSeconds": 7200
    }
  ]
}
